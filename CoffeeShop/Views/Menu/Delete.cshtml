@model CoffeeShop.Models.Menu

<h2>Delete Menu</h2>

<div class="alert alert-danger">

    Are you sure you want to delete this menu?

</div>

<table class="table">

    <tr>

        <th>Name</th>

        <td>@Model.MenuName</td>

    </tr>

    <tr>

        <th>Price</th>

        <td>@Model.Price</td>

    </tr>

    <tr>

        <th>Category</th>

        <td>@Model.Category?.CategoryName</td>

    </tr>

</table>

<form asp-action="Delete">

    <input asp-for="MenuID" type="hidden" />

    <button class="btn btn-danger">

        Delete

    </button>

    <a asp-action="Index"
       class="btn btn-secondary">

        Cancel

    </a>

</form>