@model CoffeeShop.Models.Order

@{
    ViewData["Title"] = "Order Detail";
}

<div class="container mt-4">

    <h2 class="mb-4">Order Detail</h2>

    <table class="table table-bordered">

        <tr>
            <th width="200">Order ID</th>
            <td>@Model.OrderID</td>
        </tr>

        <tr>
            <th>Order Date</th>
            <td>@Model.OrderDate.ToString("dd/MM/yyyy")</td>
        </tr>

        <tr>
            <th>Customer</th>
            <td>@Model.Customer?.CustomerName</td>
        </tr>

        <tr>
            <th>Employee</th>
            <td>@Model.Employee?.FullName</td>
        </tr>

        <tr>
            <th>Total Amount</th>
            <td class="text-danger fw-bold">
                @Model.TotalPrice.ToString("N0") đ
            </td>
        </tr>

    </table>

    <a asp-action="Edit"
       asp-route-id="@Model.OrderID"
       class="btn btn-warning">

        Edit

    </a>

    <a asp-action="Index"
       class="btn btn-secondary">

        Back

    </a>

</div>