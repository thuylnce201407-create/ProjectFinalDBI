@model CoffeeShop.Models.Order

@{
    ViewData["Title"] = "Invoice";
}

<div class="container mt-4">

    <h2>Invoice</h2>

    <h5>
        Customer:
        @Model.Customer?.CustomerName
    </h5>

    <h5>
        Employee:
        @Model.Employee?.FullName
    </h5>

    <hr />

    <table class="table table-bordered">

        <thead class="table-dark">

            <tr>

                <th>Menu</th>

                <th>Price</th>

                <th>Qty</th>

                <th>Total</th>

            </tr>

        </thead>

        <tbody>

            @foreach (var item in Model.OrderDetails!)
            {
                <tr>

                    <td>@item.Menu?.MenuName</td>

                    <td>@item.Menu?.Price.ToString("N0") đ</td>

                    <td>@item.Quantity</td>

                    <td>
                        @((item.Menu!.Price * item.Quantity).ToString("N0")) đ
                    </td>

                </tr>
            }

        </tbody>

        <tfoot>

            <tr>

                <th colspan="3" class="text-end">

                    Grand Total

                </th>

                <th class="text-danger">

                    @Model.TotalPrice.ToString("N0") đ

                </th>

            </tr>

        </tfoot>

    </table>

</div>