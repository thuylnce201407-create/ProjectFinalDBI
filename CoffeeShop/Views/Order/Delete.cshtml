@model CoffeeShop.Models.Order

@{
    ViewData["Title"] = "Delete Order";
}

<div class="container mt-4">

    <h2>Delete Order</h2>

    <div class="alert alert-danger">

        Are you sure you want to delete this order?

    </div>

    <table class="table table-bordered">

        <tr>

            <th>Customer</th>

            <td>@Model.Customer?.CustomerName
            </td>

        </tr>

        <tr>

            <th>Employee</th>

            <td>@Model.Employee?.FullName</td>

        </tr>

        <tr>
            <th>Date</th>
            <td>@Model.OrderDate.ToShortDateString()</td>
        </tr>


    </table>

    <form asp-action="Delete">

        <input type="hidden"
               asp-for="OrderID" />

        <button class="btn btn-danger">
            Delete
        </button>

        <a asp-action="Index"
           class="btn btn-secondary">
            Cancel
        </a>

    </form>

</div>