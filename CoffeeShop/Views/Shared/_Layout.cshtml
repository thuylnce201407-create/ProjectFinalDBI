<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CoffeeShop</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/CoffeeShop.styles.css" asp-append-version="true" />
</head>

<body>

    @{
        var role = Context.Session.GetString("Role");
    }

    <header>

        <nav class="navbar navbar-expand-lg navbar-dark bg-dark">

            <div class="container">

                <a class="navbar-brand"
                   asp-controller="Home"
                   asp-action="Index">
                    ☕ CoffeeShop
                </a>

                <button class="navbar-toggler"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#navbarNav">

                    <span class="navbar-toggler-icon"></span>

                </button>

                <div class="collapse navbar-collapse"
                     id="navbarNav">

                    <ul class="navbar-nav ms-auto">

                        <!-- Luôn hiện -->
                        <li class="nav-item">
                            <a class="nav-link"
                               asp-controller="Home"
                               asp-action="Index">
                                Home
                            </a>
                        </li>

                        @if (role == "Employee")
                        {
                            <li class="nav-item">
                                <a class="nav-link"
                                   asp-controller="Menu"
                                   asp-action="Index">
                                    Menu
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link"
                                   asp-controller="Category"
                                   asp-action="Index">
                                    Category
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link"
                                   asp-controller="Employee"
                                   asp-action="Index">
                                    Employee
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link"
                                   asp-controller="Customer"
                                   asp-action="Index">
                                    Customer
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link"
                                   asp-controller="Order"
                                   asp-action="Index">
                                    Orders
                                </a>
                            </li>

                            <li class="nav-item">
                                <span class="nav-link text-warning fw-bold">
                                    👋 Hello @Context.Session.GetString("FullName")
                                </span>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-danger"
                                   asp-controller="Account"
                                   asp-action="Logout">
                                    Logout
                                </a>
                            </li>
                        }
                        else if (role == "Customer")
                        {
                            <li class="nav-item">
                                <a class="nav-link"
                                   asp-controller="Cart"
                                   asp-action="Index">
                                    Cart
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link"
                                   asp-controller="Order"
                                   asp-action="MyOrders">
                                    My Orders
                                </a>
                            </li>

                            <li class="nav-item">
                                <span class="nav-link text-warning fw-bold">
                                    👋 Hello @Context.Session.GetString("FullName")
                                </span>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-danger"
                                   asp-controller="Account"
                                   asp-action="Logout">
                                    Logout
                                </a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link"
                                   asp-controller="Account"
                                   asp-action="Login">
                                    Login
                                </a>
                            </li>
                        }

                    </ul>

                </div>

            </div>

        </nav>

    </header>

    <main role="main">
        @RenderBody()
    </main>

    <footer>
        <div class="container text-center">
            © 2026 - CoffeeShop
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>