@model List<CoffeeShop.Models.Menu>

@{
    ViewData["Title"] = "Coffee Shop";
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success text-center">
        @TempData["Success"]
    </div>
}

@if (TempData["Message"] != null)
{
    <div class="alert alert-warning text-center">
        @TempData["Message"]
    </div>
}

<!-- ================= HERO ================= -->

<section class="hero-section">

    <div class="container-fluid px-5">

        <div class="row align-items-center min-vh-100">

            <div class="col-lg-12 text-center">

                <h1>
                    ☕ Coffee Shop
                </h1>

                <p class="lead">
                    Fresh Coffee - Fresh Day
                </p>

                <p>
                    Enjoy the best coffee made from premium beans.
                </p>

                <a href="#menu"
                   class="btn btn-light btn-lg">

                    Order Now

                </a>

            </div>

            

        </div>

    </div>

</section>

<!-- ================= MENU ================= -->

<section class="menu-section" id="menu">

    <div class="container">

        <!-- Search -->

        <div class="row mb-5">

            <div class="col-md-6 mx-auto">

                <form asp-action="Index" method="get">

                    <div class="input-group">

                        <input class="form-control"
                               name="keyword"
                               value="@ViewBag.Keyword"
                               placeholder="Search coffee..." />

                        <button class="btn btn-dark">

                            Search

                        </button>

                    </div>

                </form>

            </div>

        </div>

        <!-- Category -->

        <div class="text-center mb-5">

            <a asp-action="Index"
               class="btn @(ViewBag.SelectedCategory == null ? "btn-dark" : "btn-outline-dark") m-2">

                All

            </a>

            @foreach (var category in ViewBag.Categories)
            {
                <a asp-action="Index"
                   asp-route-categoryId="@category.CategoryID"
                   class="btn @(ViewBag.SelectedCategory == category.CategoryID ? "btn-dark" : "btn-outline-dark") m-2">

                    @category.CategoryName

                </a>
            }

        </div>

        <!-- Title -->

        <div class="text-center mb-5">

            <h2 class="fw-bold">

                Our Coffee Menu

            </h2>

            <p class="text-muted">

                Freshly brewed coffee made with love ❤️

            </p>

        </div>

        <!-- Product -->

        <div class="row">

            @foreach (var item in Model)
            {
                <div class="col-lg-4 mb-4">

                    <div class="card shadow h-100">

                        <img src="@item.ImageUrl"
                             class="card-img-top">

                        <div class="card-body text-center">

                            <h4>

                                @item.MenuName

                            </h4>

                            <h5 class="text-danger fw-bold">

                                @item.Price.ToString("N0") đ

                            </h5>

                            <p>

                                @item.Description

                            </p>

                            <div class="mb-3">

                                @if (item.Category?.CategoryName == "Coffee")
                                {
                                    <span class="badge bg-dark">

                                        ☕ Coffee

                                    </span>
                                }
                                else if (item.Category?.CategoryName == "Tea")
                                {
                                    <span class="badge bg-success">

                                        🍵 Tea

                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark">

                                        🍰 Cake

                                    </span>
                                }

                            </div>

                            <div class="d-grid gap-2">

                                <a asp-action="Detail"
                                   asp-route-id="@item.MenuID"
                                   class="btn btn-primary">

                                    View Detail

                                </a>

                                <a asp-controller="Cart"
                                   asp-action="Add"
                                   asp-route-id="@item.MenuID"
                                   class="btn btn-success">

                                    Add To Cart

                                </a>

                            </div>

                        </div>

                    </div>

                </div>

            }

        </div>

    </div>

</section>